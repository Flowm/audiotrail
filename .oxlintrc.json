{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "import", "vue"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "consistent-function-scoping": "off",
    "import/no-unassigned-import": ["warn", { "allow": ["**/*.css", "**/echarts"] }],
    "no-console": "off",
    "no-await-in-loop": "off",
    "no-map-spread": "off",
    "no-underscore-dangle": "off"
  },
  "env": {
    "builtin": true,
    "browser": true,
    "vue": true
  },
  "ignorePatterns": ["dist", "data"]
}
