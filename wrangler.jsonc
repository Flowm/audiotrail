{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "audiotrail",
  "compatibility_date": "2026-03-10",
  "send_metrics": false,
  "routes": [
    {
      "pattern": "audiotrail.frcy.org",
      "custom_domain": true,
    },
  ],
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
  },
  "observability": {
    "enabled": true,
  },
}
